    <!-- Onboarding -->
    <string name="onboarding_title_1">Vítej v GeoReminderu</string>
    <string name="onboarding_text_1">Připomene ti úkoly přesně ve chvíli, kdy jsi na správném místě – nebo ve správný čas. „Koupit mléko, až budu u obchodu.“</string>
    <string name="onboarding_title_2">Poloha „Povolit vždy“</string>
    <string name="onboarding_text_2">Aby připomínka přišla i se zavřenou appkou, potřebuje Android svolit polohu „Povolit vždy“. Hlídání dělá úsporně systém – baterii to prakticky nezatěžuje.</string>
    <string name="onboarding_title_3">Notifikace</string>
    <string name="onboarding_text_3">Bez notifikací ti appka nemá jak dát vědět. V dalším kroku je prosím povol – stejně jako přístup k poloze.</string>
    <string name="onboarding_button_continue">Pokračovat</string>
